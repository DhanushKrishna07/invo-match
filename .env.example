# ================================
# Invo Match - Environment Variables
# Copy this file to .env and fill in your values
# ================================

# n8n General Configuration
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_API_KEY=your_n8n_api_key_here
N8N_ENCRYPTION_KEY=your_long_random_encryption_key_here
GENERIC_TIMEZONE=Asia/Kolkata
TZ=Asia/Kolkata

# Postgres Database Configurations
POSTGRES_N8N_USER=n8n
POSTGRES_N8N_PASSWORD=your_n8n_db_password_here
POSTGRES_N8N_DB=n8n

POSTGRES_NOCODB_USER=nocodb
POSTGRES_NOCODB_PASSWORD=your_nocodb_db_password_here
POSTGRES_NOCODB_DB=nocodb

# NocoDB Configuration
NOCODB_BASE_URL=http://localhost:8080
# Set these after initial setup/provisioning
NOCODB_API_TOKEN=your_nocodb_api_token_here
NOCODB_BASE_ID=your_nocodb_base_id_here

# NocoDB Table IDs (dynamically populated by setup_nocodb.js)
NOCODB_VENDORS_TABLE_ID=your_vendors_table_id
NOCODB_PURCHASE_ORDERS_TABLE_ID=your_purchase_orders_table_id
NOCODB_PO_LINE_ITEMS_TABLE_ID=your_po_line_items_table_id
NOCODB_INVOICES_TABLE_ID=your_invoices_table_id
NOCODB_INVOICE_LINE_ITEMS_TABLE_ID=your_invoice_line_items_table_id
NOCODB_VALIDATION_RESULTS_TABLE_ID=your_validation_results_table_id
NOCODB_AUDIT_LOG_TABLE_ID=your_audit_log_table_id

# AI Extraction Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email Ingestion Configuration (IMAP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_email_app_password
IMAP_MAILBOX=INBOX

# Email Sending Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password

# Routing Notifications
PROCUREMENT_REVIEW_EMAIL=reviewer@example.com
RECIPIENT_EMAIL=accounting@example.com
SENDER_EMAIL=your_email@gmail.com

# Credential Caching (auto-populated by wire-workflows.js)
N8N_IMAP_CRED_ID=your_imap_cred_id
N8N_SMTP_CRED_ID=your_smtp_cred_id

